{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "event-schema/v1",
  "title": "EventDTO",
  "description": "Normalized offline event from any aggregator scraper",
  "type": "object",
  "required": [
    "title",
    "category_slug",
    "city_slug",
    "start_at",
    "source_url",
    "source_slug",
    "is_online"
  ],
  "properties": {
    "external_id": {
      "type": ["string", "null"],
      "description": "ID in the source system"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "Canonical event page URL"
    },
    "source_slug": {
      "type": "string",
      "enum": ["yandex_afisha", "kudago"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "description": {
      "type": ["string", "null"]
    },
    "category_slug": {
      "type": "string",
      "enum": [
        "concerts",
        "exhibitions",
        "theater",
        "sport",
        "education",
        "other"
      ]
    },
    "city_slug": {
      "type": "string",
      "description": "Internal city slug, e.g. moscow, spb"
    },
    "venue": {
      "type": ["string", "null"],
      "description": "Physical venue name; required for offline events"
    },
    "start_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC"
    },
    "end_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "price_type": {
      "type": "string",
      "enum": ["free", "paid", "unknown"],
      "default": "unknown"
    },
    "price_text": {
      "type": ["string", "null"],
      "examples": ["Бесплатно", "от 1500 ₽", "уточняйте на сайте"]
    },
    "is_online": {
      "type": "boolean",
      "const": false,
      "description": "Must be false; online events are filtered out"
    },
    "image_url": {
      "type": ["string", "null"],
      "format": "uri"
    }
  },
  "additionalProperties": false
}
