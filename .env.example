BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_llm_api_key
OPENAI_API_BASE=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# socks5://127.0.0.1:10808 or tg://proxy?server=...&port=...&secret=...
TELEGRAM_PROXY=
# ScrapingBee — обход блокировок и капчи при HTML-скрапинге (https://www.scrapingbee.com)
SCRAPINGBEE_API_KEY=
SCRAPINGBEE_STEALTH=false
SCRAPINGBEE_COUNTRY_CODE=ru
# Crawlee (локальный Node.js скрапер без API-токенов)
CRAWLEE_ENABLED=true
